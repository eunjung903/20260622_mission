# Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 이메일 발송 (선택 - 미설정 시 FormSubmit API 사용)
# Brevo (https://app.brevo.com) - 300통/일 무료, API 키 + 발신 이메일 필요
BREVO_API_KEY=
EMAIL_FROM=AI 뉴스 리포터 <your@email.com>

# Resend (https://resend.com)
RESEND_API_KEY=

# Gmail SMTP (로컬 개발용)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
