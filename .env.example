# Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 이메일 발송 (선택 - 미설정 시 FormSubmit API로 자동 발송)
# Resend 사용 시 (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=AI 뉴스 리포터 <onboarding@resend.dev>

# Gmail SMTP 사용 시 (로컬 개발용)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
